# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPCIONAL - POOL DE CHAVES GEMINI (para testes e contingência)
# Você pode definir chaves adicionais para rotacionar automaticamente quando houver rate limit.
# Também é possível passar uma lista separada por vírgulas em GEMINI_API_KEY.
GEMINI_API_KEY_1="SUA_CHAVE_GEMINI_SECUNDARIA_1"
GEMINI_API_KEY_2="SUA_CHAVE_GEMINI_SECUNDARIA_2"
GEMINI_API_KEY_3="SUA_CHAVE_GEMINI_SECUNDARIA_3"
GEMINI_API_KEY_4="SUA_CHAVE_GEMINI_SECUNDARIA_4"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Password to authorize sheet editing/uploading in the Portal do Staff
ADMIN_PASSWORD="destine26"

# GOOGLE_SHEET_URL: Public Google Sheets URL for serverless real-time synchronization on Vercel
GOOGLE_SHEET_URL="https://docs.google.com/spreadsheets/d/your-spreadsheet-id/edit?usp=sharing"

# GOOGLE_SHEET_TABS: Comma-separated list of sheet/tab names to load from the spreadsheet
GOOGLE_SHEET_TABS="Geral,Protocolos_Saude,Fornecedores_Principais"

# GOOGLE SHEETS TRANSACTION LOGGING (Opcional - Para salvar logs de conversação no Sheets via Service Account)
GOOGLE_CLIENT_EMAIL="seu-service-account@projeto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----"
GOOGLE_SHEETS_LOG_SPREADSHEET_ID="id-da-planilha-de-logs-do-sheets"


